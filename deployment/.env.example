# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MQTT Configuration (Docker Compose uses NanoMQ; TLS verify uses this name against the server cert SAN)
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USE_TLS=true
MQTT_TLS_SKIP_VERIFY=true
# Broker hostname in Compose is "nanomq" (see infrastructure/certs/generate-certs.sh)
MQTT_TLS_SERVER_NAME=nanomq
MQTT_TLS_CA_CERT=/certs/ca.crt
MQTT_TLS_REQUIRE_EDGE_CERT=false
MQTT_TLS_EDGE_CERT=/certs/edge.crt
MQTT_TLS_EDGE_KEY=/certs/edge.key

# Device Service
DEVICE_SERVICE_MQTT_USERNAME=device-service
DEVICE_SERVICE_MQTT_PASSWORD=device-service_password

# Service Tokens
SERVICE_TOKEN=dev-token

# Service Listen Addresses
LISTEN_ADDR=:8080
GRPC_ADDR=:9090
GRPC_PORT=9090

# Lightning Service Configuration
LND_HOST=host.docker.internal:10001
LND_TLS_CERT_HEX=2d2d2d2d2d424....
LND_MACAROON_HEX=0201036c6e6402f80...
LIGHTNING_RPC_TIMEOUT_SECONDS=30

# OpenTelemetry Configuration
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp # none
OTEL_EXPORTER_OTLP_PROTOCOL=grpc # none
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317 # empty

# Gin Mode
GIN_MODE=release

# External Services

## Auto Pay
AUTOPAY_ENABLED=false # true 

RECEIVER_LND_HOST=host.docker.internal:10001
RECEIVER_LND_TLS_CERT_HEX=2d2d2d2d2d4...
RECEIVER_LND_TLS_SERVER_NAME=localhost
RECEIVER_LND_MACAROON_HEX=0201036c6e6402...

PAYER_LND_HOST=host.docker.internal:10002
PAYER_LND_TLS_CERT_HEX=2d2d2d2d2d4...
PAYER_LND_TLS_SERVER_NAME=localhost
PAYER_LND_MACAROON_HEX=0201036c6e6402...

## Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

## Prometheus
PROMETHEUS_TARGET_HOST=host.docker.internal

## Devices
HTTP_DEVICES_MQTT_BROKER=host.docker.internal
SMARTMETER_MQTT_BROKER=host.docker.internal
