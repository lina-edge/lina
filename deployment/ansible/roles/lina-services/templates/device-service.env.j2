DB_PATH={{ lina_lib_dir }}/device/devices.db
API_ADDR={{ lina_device_api_addr }}
METRICS_ADDR={{ lina_device_metrics_addr }}
MQTT_BROKER={{ lina_mqtt_broker }}
MQTT_USE_TLS={{ lina_mqtt_use_tls | bool | ternary('true', 'false') }}
MQTT_PORT={{ lina_nanomq_plain_port | int }}
MQTT_TLS_PORT={{ lina_nanomq_tls_port | int }}
MQTT_USERNAME={{ lina_device_mqtt_username }}
MQTT_PASSWORD={{ lina_device_mqtt_password }}
MQTT_TLS_SKIP_VERIFY={{ lina_mqtt_tls_skip_verify | default(false) | bool | ternary('true', 'false') }}
MQTT_TLS_SERVER_NAME={{ lina_mqtt_tls_server_name | default('') }}
MQTT_TLS_CA_CERT={{ lina_nanomq_cafile if (lina_mqtt_use_tls | default(false) | bool) else '' }}
MQTT_TLS_REQUIRE_EDGE_CERT=false
MQTT_TLS_EDGE_CERT=
MQTT_TLS_EDGE_KEY=
REDIS_HOST={{ lina_redis_host }}
REDIS_PORT={{ lina_redis_port }}
REDIS_DB=0
{% if (lina_redis_password | default('') | string | length) > 0 %}
REDIS_PASSWORD={{ lina_redis_password }}
{% endif %}
LEDGER_GRPC_HOST=127.0.0.1
LEDGER_GRPC_PORT={{ lina_ledger_grpc_addr | regex_replace('^.*:', '') }}
LIGHTNING_GRPC_HOST=127.0.0.1
LIGHTNING_GRPC_PORT={{ lina_lightning_grpc_addr | regex_replace('^.*:', '') }}
LIGHTNING_RPC_TIMEOUT_SECONDS=30
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=device-service
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
GIN_MODE=release
