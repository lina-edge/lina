DB_PATH={{ lina_lib_dir }}/ledger/ledger.db
SERVICE_TOKEN={{ lina_service_token }}
LISTEN_ADDR={{ lina_ledger_listen_addr }}
GRPC_ADDR={{ lina_ledger_grpc_addr }}
METRICS_ADDR={{ lina_ledger_metrics_addr }}
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
{% if (lina_redis_password | default('') | string | length) > 0 %}
REDIS_PASSWORD={{ lina_redis_password }}
{% endif %}
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ledger-service
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
GIN_MODE=release
