# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MQTT Configuration
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USE_TLS=true
MQTT_TLS_SKIP_VERIFY=false
MQTT_TLS_SERVER_NAME=mosquitto
MQTT_TLS_CA_CERT=/certs/ca.crt
MQTT_TLS_REQUIRE_EDGE_CERT=false
MQTT_TLS_EDGE_CERT=/certs/edge.crt
MQTT_TLS_EDGE_KEY=/certs/edge.key
MQTT_CLIENT_ID=device-service
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DYNSEC_ADMIN_USER=
MQTT_DYNSEC_ADMIN_PASSWORD=

# Service Tokens
SERVICE_TOKEN=dev-token

# Service Listen Addresses
LISTEN_ADDR=:8080
GRPC_ADDR=:9090

# Lightning Service Configuration
LND_TLS_CERT_HEX=
LND_MACAROON_HEX=
LIGHTNING_RPC_TIMEOUT_SECONDS=30

# Smart Meter Configuration
SMART_METER_DEVICE_ID=smart-meter-001
SMART_METER_MQTT_USERNAME=smart-meter-001
SMART_METER_MQTT_PASSWORD=smart-meter-001_password

# OpenTelemetry Configuration
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317

# Gin Mode
GIN_MODE=release

